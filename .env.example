# Copy to .env (not committed to git):  cp .env.example .env
# On Kali after clone: copy your real .env from Windows or fill these two lines.

TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather
TELEGRAM_CHAT_ID=6874845252
TELEGRAM_AUTO=1
# Mirror GUI scans to Telegram (start + finish). Set 0 to disable.
TELEGRAM_MIRROR_GUI=1
# Kali: use 1 or remove line. Windows SSL issues: TELEGRAM_SSL_VERIFY=0
TELEGRAM_SSL_VERIFY=1

# AI (optional — required for AI Guided Scan LLM routing + comprehensive report)
GEMINI_API_KEY=your_gemini_api_key_here
# Free tier (AI Studio): strongest = gemini-3-flash-preview, stable = gemini-2.5-flash
GEMINI_MODEL=gemini-3-flash-preview
# Tried in order if primary returns 404/503/429
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-lite
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Free tier (no paid credits needed): https://openrouter.ai/deepseek/deepseek-v4-flash:free
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter leaderboard headers
# OPENROUTER_HTTP_REFERER=https://github.com/your/repo
# OPENROUTER_APP_TITLE=AUTO-PWN Router
# Set 1 only if OpenRouter fails (402 on paid models, etc.)
AI_SKIP_OPENROUTER=0
# Default with :free model: openrouter first, then Gemini fallback
AI_PROVIDER_ORDER=openrouter,gemini,nvidia
NVIDIA_API_KEY=your_nvidia_api_key_here
# AI Guided Scan: max tool steps per run (default 12)
AI_ORCHESTRATOR_MAX_STEPS=12
# Optional per-step Arabic notes (extra API calls); default off
AI_ORCHESTRATOR_STEP_NOTES=0
