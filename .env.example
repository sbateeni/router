# Telegram bot + notifications
# 1) Create bot: message @BotFather → /newbot → copy token
# 2) Get chat id: message your bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Run bot (pick one):
#   python3 master_pwn.py              ← auto-starts bot if .env is set (default)
#   python3 master_pwn.py --telegram   ← same
#   python3 telegram_pwn.py            ← same shortcut
#   python3 master_pwn.py --no-telegram  ← local menu on Kali terminal
# Set TELEGRAM_AUTO=0 in .env to disable auto-start and always show local menu
TELEGRAM_AUTO=1

# AI tools (menu 11–14 only — not used in classic --auto scan)
# During scan: tool selection, Hydra commands, RouterSploit follow-up
# After scan: final Arabic report (AI_ANALYSIS.txt)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Nuclei (optional)
# NUCLEI_PATH=tools/nuclei/nuclei.exe
# NUCLEI_TAGS=default-logins,cves,misconfiguration,exposed-panel,hikvision,upnp,rce,zte
